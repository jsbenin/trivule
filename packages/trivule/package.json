{
  "name": "trivule",
  "version": "2.0.1-alpha.1",
  "description": "Trivule is a user-friendly JavaScript library for HTML form validation.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "typings": "./types/index.d.ts",
  "files": [
    "./dist",
    "./types"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/trivule/trivule"
  },
  "docs": "https://trivule.com",
  "scripts": {
    "test": "vitest run",
    "test-watch": "vitest",
    "dev": "vite",
    "build": "tsc && vite build",
    "build:watch": "tsc && vite build --watch",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "keywords": [
    "Validation, Form validation, HTML form validator"
  ],
  "author": "Fassinou Claude (dev.claudy@gmail.com) and contributors",
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.10.0",
    "@typescript-eslint/parser": "^7.10.0",
    "@vitest/ui": "^3.2.4",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^9.1.7",
    "jsdom": "^24.0.0",
    "prettier": "^3.2.5",
    "ts-node": "^10.9.1",
    "typescript": "^5.4.5",
    "vite": "^4.3.2",
    "vitest": "^3.2.4"
  }
}
