{
    "name": "trivule-vscode-extension",
    "publisher": "trivule",
    "repository": {
        "type": "git",
        "url": "https://github.com/jsbenin/trivule.git"
    },
    "displayName": "Trivule",
    "description": "Auto-completion for Trivule library in HTML files",
	"icon": "icon.png",
    "version": "0.1.1",
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onLanguage:html",
        "onLanguage:php",
        "onLanguage:blade",
        "onLanguage:vue",
        "onLanguage:svelte",
        "onLanguage:astro",
        "onLanguage:ejs",
        "onLanguage:handlebars",
        "onLanguage:mustache",
        "onLanguage:nunjucks",
        "onLanguage:pug",
        "onLanguage:twig",
        "onLanguage:erb",
        "onLanguage:edge",
        "onLanguage:eex",
        "onLanguage:jinja",
        "onLanguage:gotemplate"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "html",
                "extensions": [
                    ".html", ".htm"
                ]
            },
            {
                "id": "php",
                "extensions": [
                    ".php"
                ]
            },
            {
                "id": "blade",
                "extensions": [
                    ".blade.php"
                ]
            },
            {
                "id": "vue",
                "extensions": [
                    ".vue"
                ]
            },
            {
                "id": "svelte",
                "extensions": [
                    ".svelte"
                ]
            },
            {
                "id": "astro",
                "extensions": [
                    ".astro"
                ]
            },
            {
                "id": "ejs",
                "extensions": [
                    ".ejs"
                ]
            },
            {
                "id": "handlebars",
                "extensions": [
                    ".hbs", ".handlebars"
                ]
            },
            {
                "id": "mustache",
                "extensions": [
                    ".mustache"
                ]
            },
            {
                "id": "nunjucks",
                "extensions": [
                    ".njk"
                ]
            },
            {
                "id": "pug",
                "extensions": [
                    ".pug", ".jade"
                ]
            },
            {
                "id": "twig",
                "extensions": [
                    ".twig"
                ]
            },
            {
                "id": "erb",
                "extensions": [
                    ".erb", ".html.erb"
                ]
            },
            {
                "id": "edge",
                "extensions": [
                    ".edge"
                ]
            },
            {
                "id": "eex",
                "extensions": [
                    ".eex", ".html.eex", ".heex", ".html.heex"
                ]
            },
            {
                "id": "jinja",
                "extensions": [
                    ".j2", ".jinja", ".jinja2", ".html.j2", ".html.jinja", ".html.jinja2"
                ]
            },
            {
                "id": "gotemplate",
                "extensions": [
                    ".tmpl", ".tpl", ".gohtml", ".html.tmpl", ".html.tpl"
                ]
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile",
        "lint": "eslint src --ext ts",
        "test": "node ./out/test/runTest.js"
    },
    "devDependencies": {
        "@types/glob": "^9.0.0",
        "@types/mocha": "^10.0.10",
        "@types/node": "^18.19.130",
        "@types/vscode": "^1.80.0",
        "@vscode/test-electron": "^2.5.2",
        "glob": "^13.0.0",
        "mocha": "^11.7.5",
        "typescript": "^5.0.0"
    }
}
