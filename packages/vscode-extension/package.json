{
    "name": "trivule",
    "publisher": "trivule",
    "repository": {
        "type": "git",
        "url": "https://github.com/jsbenin/trivule.git"
    },
    "displayName": "Trivule VS Code Extension",
    "description": "Auto-completion for Trivule library in HTML files",
    "version": "0.0.2",
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onLanguage:html"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "html",
                "extensions": [
                    ".html"
                ]
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "devDependencies": {
        "@types/vscode": "^1.80.0",
        "@types/node": "^18.0.0",
        "typescript": "^5.0.0"
    }
}