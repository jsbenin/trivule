{
    "name": "trivule-vscode-extension",
    "publisher": "trivule",
    "repository": {
        "type": "git",
        "url": "https://github.com/jsbenin/trivule.git"
    },
    "displayName": "Trivule",
    "description": "Auto-completion for Trivule library in HTML files",
	"icon": "icon.png",
    "version": "0.1.1",
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onLanguage:html"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "html",
                "extensions": [
                    ".html", ".blade.php", ".php"
                ]
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile",
        "lint": "eslint src --ext ts",
        "test": "node ./out/test/runTest.js"
    },
    "devDependencies": {
        "@types/glob": "^9.0.0",
        "@types/mocha": "^10.0.10",
        "@types/node": "^18.19.130",
        "@types/vscode": "^1.80.0",
        "@vscode/test-electron": "^2.5.2",
        "glob": "^13.0.0",
        "mocha": "^11.7.5",
        "typescript": "^5.0.0"
    }
}
